diff -Naur a/ext/curl/config.m4 b/ext/curl/config.m4
--- a/ext/curl/config.m4	2019-01-09 09:54:13.000000000 +0000
+++ b/ext/curl/config.m4	2023-11-01 12:42:00.382872400 +0000
@@ -6,12 +6,12 @@
 [  --with-curl[=DIR]         Include cURL support])
 
 if test "$PHP_CURL" != "no"; then
