msgstr ""
"Siz yulduzcha va qiyshiq chiziq yordamida intervallarni belgilashingiz "
"mumkin. masalan. */2 (har 2 daqiqada)"

#, vue-format
msgid "You can specify spans using a dash. e.g. 5-7 (minutes 5 to 7)"
msgstr ""
