<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AdminiCore Dashboard - Admini Control Panel</title>
    <link rel="stylesheet" href="/static/css/admini-theme.css">
    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
</head>
<body>
    
    <div class="admini-header">
        <div class="admini-flex admini-justify-between admini-items-center">
            <div>
                <h1>AdminiCore</h1>
                <div class="panel-title">AdminiCore Dashboard</div>
            </div>
            <div style="color: rgba(255,255,255,0.9); font-size: 0.9rem;">
                Welcome, admin | <a href="/CMD_LOGOUT" style="color: white; text-decoration: underline;">Logout</a>
            </div>
        </div>
    </div>

    
    <nav class="admini-nav">
        <ul>
            
            <li><a href="/CMD_ADMIN" class="active">Dashboard</a></li>
            <li><a href="/CMD_ADMIN_STATS" class="">Statistics</a></li>
            <li><a href="/CMD_SHOW_USERS" class="">Users</a></li>
            <li><a href="/CMD_SHOW_RESELLERS" class="">Resellers</a></li>
            <li><a href="/CMD_IP_MANAGER" class="">IP Management</a></li>
            <li><a href="/CMD_ADMIN_SETTINGS" class="">Settings</a></li>
            <li><a href="/CMD_SYSTEM_INFO" class="">System Info</a></li>
            
        </ul>
    </nav>

    
    <div class="admini-dashboard">
        
        
        <div class="admini-grid admini-grid-3">
            <div class="admini-stat-card">
                <div class="admini-stat-number">142</div>
                <div class="admini-stat-label">Total Users</div>
            </div>
            <div class="admini-stat-card">
                <div class="admini-stat-number">367</div>
                <div class="admini-stat-label">Total Domains</div>
            </div>
            <div class="admini-stat-card">
                <div class="admini-stat-number">0.25</div>
                <div class="admini-stat-label">Server Load</div>
            </div>
        </div>

        <div class="admini-grid admini-grid-2" style="margin-top: 2rem;">
            <div class="admini-card">
                <div class="admini-card-header">
                    <h3>System Information</h3>
                </div>
                <div class="admini-card-body">
                    <table class="admini-table">
                        <tr><td><strong>Hostname:</strong></td><td>server.example.com</td></tr>
                        <tr><td><strong>OS:</strong></td><td>CentOS Stream 8</td></tr>
                        <tr><td><strong>Kernel:</strong></td><td>4.18.0</td></tr>
                        <tr><td><strong>Admini Version:</strong></td><td>1.680</td></tr>
                        <tr><td><strong>Uptime:</strong></td><td>15 days, 3 hours</td></tr>
                    </table>
                </div>
            </div>

            <div class="admini-card">
                <div class="admini-card-header">
                    <h3>Service Status</h3>
                </div>
                <div class="admini-card-body">
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <div class="admini-flex admini-justify-between admini-items-center">
                            <span>Apache</span>
                            <span class="admini-status admini-status-active">Running</span>
                        </div>
                        <div class="admini-flex admini-justify-between admini-items-center">
                            <span>MySQL</span>
                            <span class="admini-status admini-status-active">Running</span>
                        </div>
                        <div class="admini-flex admini-justify-between admini-items-center">
                            <span>Mail Server</span>
                            <span class="admini-status admini-status-active">Running</span>
                        </div>
                        <div class="admini-flex admini-justify-between admini-items-center">
                            <span>DNS</span>
                            <span class="admini-status admini-status-active">Running</span>
                        </div>
                        <div class="admini-flex admini-justify-between admini-items-center">
                            <span>FTP</span>
                            <span class="admini-status admini-status-active">Running</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            console.log('Admini Control Panel loaded');
            
            
            
            setInterval(function() {
                
                console.log('Stats refresh interval');
            }, 30000);
            
        });
    </script>
</body>
</html>
